---
const scenarios = [
  {
    label: 'Quick pulse survey',
    detail: '500 responses · avg 15 words each',
    perResponse: '$10.00',
    codesift: '~$0.90',
    savings: '91%',
  },
  {
    label: 'NPS verbatims',
    detail: '1,000 responses · avg 40 words each',
    perResponse: '$20.00',
    codesift: '~$4.15',
    savings: '79%',
  },
  {
    label: 'Post-purchase feedback',
    detail: '2,500 responses · avg 30 words each',
    perResponse: '$50.00',
    codesift: '~$7.70',
    savings: '85%',
  },
  {
    label: 'Research interviews',
    detail: '100 responses · avg 200 words each',
    perResponse: '$2.00',
    codesift: '~$2.15',
    savings: '−8%',
    negative: true,
  },
];
---

<section id="pricing" class="pricing">
  <div class="container">
    <div class="pricing-header">
      <p class="section-eyebrow">Pricing model</p>
      <h2 class="section-title">Pay for data processed,<br>not for counting rows.</h2>
      <p class="section-subtitle">
        Most tools charge a flat rate per response regardless of length.
        Codesift charges based on actual content — so short answers cost
        almost nothing, and your bill reflects what you actually used.
      </p>
    </div>

    <!-- Model comparison cards -->
    <div class="model-cards">
      <div class="model-card model-other">
        <div class="model-header">
          <span class="model-label">Per-response pricing</span>
          <span class="model-badge badge-other">Others</span>
        </div>
        <div class="model-formula">
          <span class="formula-var">responses</span>
          <span class="formula-op">×</span>
          <span class="formula-rate">$0.02</span>
          <span class="formula-op">=</span>
          <span class="formula-result formula-result-high">Your bill</span>
        </div>
        <p class="model-note">
          A 3-word response and a 300-word response cost exactly the same.
          Volume punishes you. Short answers don't save you anything.
        </p>
        <ul class="model-cons">
          <li>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="6" stroke="#E05454" stroke-width="1.3"/><path d="M4.5 4.5l5 5M9.5 4.5l-5 5" stroke="#E05454" stroke-width="1.3" stroke-linecap="round"/></svg>
            Expensive for high-volume studies
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="6" stroke="#E05454" stroke-width="1.3"/><path d="M4.5 4.5l5 5M9.5 4.5l-5 5" stroke="#E05454" stroke-width="1.3" stroke-linecap="round"/></svg>
            Short responses billed same as long
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="6" stroke="#E05454" stroke-width="1.3"/><path d="M4.5 4.5l5 5M9.5 4.5l-5 5" stroke="#E05454" stroke-width="1.3" stroke-linecap="round"/></svg>
            Costs scale with survey size, not complexity
          </li>
        </ul>
      </div>

      <div class="model-divider" aria-hidden="true">
        <div class="vs-circle">vs</div>
      </div>

      <div class="model-card model-codesift">
        <div class="model-header">
          <span class="model-label">Data-based pricing</span>
          <span class="model-badge badge-codesift">Codesift</span>
        </div>
        <div class="model-formula">
          <span class="formula-var">characters</span>
          <span class="formula-op">×</span>
          <span class="formula-rate formula-rate-green">tiny rate</span>
          <span class="formula-op">=</span>
          <span class="formula-result formula-result-low">Your bill</span>
        </div>
        <p class="model-note">
          A 3-word response costs almost nothing. A 300-word response costs
          proportionally more. You pay for what you actually use.
        </p>
        <ul class="model-pros">
          <li>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="6" stroke="#4FCB8A" stroke-width="1.3"/><path d="M4 7l2.5 2.5L10 4.5" stroke="#4FCB8A" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Short responses are dramatically cheaper
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="6" stroke="#4FCB8A" stroke-width="1.3"/><path d="M4 7l2.5 2.5L10 4.5" stroke="#4FCB8A" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            High-volume studies cost a fraction
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="6" stroke="#4FCB8A" stroke-width="1.3"/><path d="M4 7l2.5 2.5L10 4.5" stroke="#4FCB8A" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Predictable, transparent billing
          </li>
        </ul>
      </div>
    </div>

    <!-- Comparison table -->
    <div class="comparison-table-wrap">
      <p class="table-intro">See how costs compare across real research scenarios</p>
      <div class="comparison-table">
        <div class="table-head">
          <span class="col-scenario">Dataset</span>
          <span class="col-other">Per-response tools</span>
          <span class="col-cs">Codesift</span>
          <span class="col-save">You save</span>
        </div>
        {scenarios.map((s) => (
          <div class="table-row">
            <div class="col-scenario">
              <span class="scenario-name">{s.label}</span>
              <span class="scenario-detail">{s.detail}</span>
            </div>
            <span class="col-other price-other">{s.perResponse}</span>
            <span class="col-cs price-codesift">{s.codesift}</span>
            <span class={`col-save save-badge${s.negative ? ' save-badge-negative' : ''}`}>{s.savings}</span>
          </div>
        ))}
      </div>
      <p class="table-disclaimer">
        * Codesift estimates based on typical data usage. Actual costs depend on response details.
        Per-response competitor rate: $0.02/response.
      </p>
    </div>
  </div>
</section>

<style>
  .pricing {
    background: var(--surface-1);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }

  .pricing-header {
    margin-bottom: 56px;
  }

  /* Model cards */
  .model-cards {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    align-items: center;
    margin-bottom: 56px;
  }

  .model-card {
    padding: 36px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
  }

  .model-other {
    background: var(--red-dim);
    border-color: rgba(224, 84, 84, 0.2);
  }

  .model-codesift {
    background: var(--green-dim);
    border-color: rgba(79, 203, 138, 0.2);
  }

  .model-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .model-label {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
  }

  .model-badge {
    font-size: 11px;
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 100px;
  }

  .badge-other {
    background: rgba(224, 84, 84, 0.15);
    color: var(--red);
    border: 1px solid rgba(224, 84, 84, 0.25);
  }

  .badge-codesift {
    background: rgba(79, 203, 138, 0.15);
    color: var(--green);
    border: 1px solid rgba(79, 203, 138, 0.25);
  }

  .model-formula {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .formula-var {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: var(--text-muted);
  }

  .formula-op {
    font-family: var(--font-display);
    font-size: 14px;
    color: var(--text-dim);
  }

  .formula-rate {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 800;
    color: var(--red);
  }

  .formula-rate-green {
    color: var(--green);
  }

  .formula-result {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    padding: 3px 12px;
    border-radius: 100px;
  }

  .formula-result-high {
    background: rgba(224, 84, 84, 0.12);
    color: var(--red);
    border: 1px solid rgba(224, 84, 84, 0.2);
  }

  .formula-result-low {
    background: rgba(79, 203, 138, 0.12);
    color: var(--green);
    border: 1px solid rgba(79, 203, 138, 0.2);
  }

  .model-note {
    font-size: 13px;
    line-height: 1.65;
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  .model-cons,
  .model-pros {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .model-cons li,
  .model-pros li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
  }

  .model-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 24px;
  }

  .vs-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--surface-3);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  /* Comparison table */
  .comparison-table-wrap {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .table-intro {
    padding: 20px 28px 0;
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 500;
  }

  .comparison-table {
    padding: 16px 0;
  }

  .table-head {
    display: grid;
    grid-template-columns: 1fr 160px 160px 100px;
    gap: 16px;
    padding: 10px 28px;
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border-subtle);
  }

  .table-row {
    display: grid;
    grid-template-columns: 1fr 160px 160px 100px;
    gap: 16px;
    align-items: center;
    padding: 16px 28px;
    border-bottom: 1px solid var(--border-subtle);
    transition: background 0.15s;
  }

  .table-row:last-child {
    border-bottom: none;
  }

  .table-row:hover {
    background: rgba(237, 232, 220, 0.02);
  }

  .scenario-name {
    display: block;
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 2px;
  }

  .scenario-detail {
    display: block;
    font-size: 12px;
    color: var(--text-muted);
  }

  .price-other {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--red);
  }

  .price-codesift {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--green);
  }

  .save-badge {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: var(--green);
    background: var(--green-dim);
    border: 1px solid rgba(79, 203, 138, 0.2);
    border-radius: 100px;
    padding: 3px 10px;
    display: inline-block;
    text-align: center;
  }

  .save-badge-negative {
    color: var(--red);
    background: var(--red-dim);
    border-color: rgba(224, 84, 84, 0.2);
  }

  .table-disclaimer {
    padding: 16px 28px;
    font-size: 12px;
    color: var(--text-muted);
    border-top: 1px solid var(--border-subtle);
    line-height: 1.6;
  }

  @media (max-width: 960px) {
    .model-cards {
      grid-template-columns: 1fr;
    }
    .model-divider {
      padding: 16px 0;
    }
    .table-head {
      grid-template-columns: 1fr 110px 110px 80px;
      padding: 10px 16px;
    }
    .table-row {
      grid-template-columns: 1fr 110px 110px 80px;
      padding: 14px 16px;
    }
  }

  @media (max-width: 600px) {
    .table-head {
      display: none;
    }
    .table-row {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
    }
    .col-scenario {
      grid-column: 1 / -1;
    }
    .col-save {
      grid-column: 2;
      text-align: right;
    }
  }
</style>
