<nav>
  <div class="container nav-inner">
    <a href="/" class="logo" aria-label="Codesift home">
      <svg width="26" height="26" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="32" height="32" rx="7" fill="#E8922A" fill-opacity="0.12"/>
        <rect x="5" y="8" width="22" height="2.5" rx="1.25" fill="#E8922A"/>
        <rect x="8" y="13.5" width="16" height="2.5" rx="1.25" fill="#E8922A" opacity="0.75"/>
        <rect x="11" y="19" width="10" height="2.5" rx="1.25" fill="#E8922A" opacity="0.5"/>
        <rect x="14" y="24.5" width="4" height="2.5" rx="1.25" fill="#E8922A" opacity="0.3"/>
      </svg>
      <span>Codesift</span>
    </a>

    <div class="nav-links">
      <div class="nav-dropdown">
        <button class="nav-dropdown-toggle" aria-haspopup="true" aria-expanded="false">
          Use Cases
          <svg width="10" height="6" viewBox="0 0 10 6" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </button>
        <div class="nav-dropdown-menu" aria-hidden="true">
          <a href="/use-cases/coding-open-ended-survey-responses">AI Coding for Survey Responses</a>
          <a href="/use-cases/thematic-analysis-for-consultants">Thematic Analysis for Consultants</a>
          <a href="/use-cases/qualitative-survey-coding-ai">Qualitative Survey Coding with AI</a>
          <a href="/compare/manual-vs-ai-coding">Manual vs AI Coding</a>
        </div>
      </div>
      <a href="/#how-it-works">How it works</a>
      <a href="/#features">Features</a>
      <a href="/#pricing">Pricing</a>
    </div>

    <div class="nav-actions">
      <a href="https://app.codesift.ai" class="nav-signin">Sign in</a>
      <a href="https://app.codesift.ai" class="btn-primary nav-cta">Get started free</a>
    </div>

    <button class="mobile-toggle" aria-label="Open menu" id="mobile-toggle">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-submenu">
      <span class="mobile-submenu-label">Use Cases</span>
      <a href="/use-cases/coding-open-ended-survey-responses">AI Coding for Survey Responses</a>
      <a href="/use-cases/thematic-analysis-for-consultants">Thematic Analysis for Consultants</a>
      <a href="/use-cases/qualitative-survey-coding-ai">Qualitative Survey Coding with AI</a>
      <a href="/compare/manual-vs-ai-coding">Manual vs AI Coding</a>
    </div>
    <a href="/#how-it-works">How it works</a>
    <a href="/#features">Features</a>
    <a href="/#pricing">Pricing</a>
    <a href="https://app.codesift.ai" class="btn-primary">Get started free</a>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.getAttribute('aria-hidden') === 'false';
    menu?.setAttribute('aria-hidden', open ? 'true' : 'false');
    toggle.classList.toggle('is-open', !open);
  });
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.setAttribute('aria-hidden', 'true');
      toggle?.classList.remove('is-open');
    });
  });

  // Desktop dropdown
  const dropdownToggle = document.querySelector('.nav-dropdown-toggle');
  const dropdownMenu = document.querySelector('.nav-dropdown-menu');
  const dropdown = document.querySelector('.nav-dropdown');

  dropdownToggle?.addEventListener('click', (e) => {
    e.preventDefault();
    const isOpen = dropdownMenu?.getAttribute('aria-hidden') === 'false';
    dropdownMenu?.setAttribute('aria-hidden', isOpen ? 'true' : 'false');
    dropdownToggle?.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    if (!dropdown?.contains(e.target as Node)) {
      dropdownMenu?.setAttribute('aria-hidden', 'true');
      dropdownToggle?.setAttribute('aria-expanded', 'false');
    }
  });
</script>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border-subtle);
    background: rgba(9, 9, 15, 0.82);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    height: 64px;
    gap: 28px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    flex-shrink: 0;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav-links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.15s;
    text-decoration: none;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-muted);
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.15s;
    padding: 0;
  }

  .nav-dropdown-toggle:hover {
    color: var(--text);
  }

  .nav-dropdown-toggle svg {
    transition: transform 0.2s;
  }

  .nav-dropdown-toggle[aria-expanded='true'] svg {
    transform: rotate(180deg);
  }

  .nav-dropdown-menu {
    position: absolute;
    top: calc(100% + 12px);
    left: 0;
    min-width: 280px;
    background: rgba(15, 15, 22, 0.96);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    padding: 6px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    z-index: 200;
  }

  .nav-dropdown-menu[aria-hidden='true'] {
    display: none;
  }

  .nav-dropdown-menu a {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-muted);
    padding: 10px 12px;
    border-radius: 6px;
    transition: background 0.15s, color 0.15s;
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-dropdown-menu a:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--text);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-left: auto;
  }

  .nav-signin {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.15s;
    text-decoration: none;
  }

  .nav-signin:hover {
    color: var(--text);
  }

  .nav-cta {
    padding: 8px 18px;
    font-size: 13px;
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    margin-left: auto;
  }

  .mobile-toggle span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .mobile-toggle.is-open span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .mobile-toggle.is-open span:nth-child(2) {
    opacity: 0;
  }
  .mobile-toggle.is-open span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 16px 24px 24px;
    gap: 4px;
    border-top: 1px solid var(--border-subtle);
    background: var(--ink);
  }

  .mobile-menu[aria-hidden='false'] {
    display: flex;
  }

  .mobile-menu a {
    font-size: 16px;
    font-weight: 500;
    color: var(--text-muted);
    padding: 10px 0;
    text-decoration: none;
    border-bottom: 1px solid var(--border-subtle);
    transition: color 0.15s;
  }

  .mobile-menu a:hover {
    color: var(--text);
  }

  .mobile-menu .btn-primary {
    margin-top: 12px;
    text-align: center;
    justify-content: center;
    border-bottom: none;
    color: #07070C;
  }

  .mobile-submenu {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-bottom: 8px;
    margin-bottom: 8px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .mobile-submenu-label {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    padding: 8px 0 4px;
    opacity: 0.6;
  }

  .mobile-submenu a {
    font-size: 15px;
    padding-left: 8px;
  }

  @media (max-width: 768px) {
    .nav-links,
    .nav-actions {
      display: none;
    }
    .mobile-toggle {
      display: flex;
    }
    .nav-dropdown-menu {
      display: none !important;
    }
  }
</style>
