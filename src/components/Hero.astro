---
---

<section class="hero">
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="container hero-grid">
    <!-- Left: Content -->
    <div class="hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        <span>Qualitative AI coding</span>
      </div>

      <h1 class="hero-title">
        Stop paying<br>
        <span class="hero-accent">per response.</span>
      </h1>

      <p class="hero-sub">
        Codesift uses AI to assign codes, themes, and categories to
        open-ended survey responses at scale. Unlike tools that charge
        per response, we price based on data processed — short answers cost
        almost nothing.
      </p>

      <div class="hero-actions">
        <a href="#" class="btn-primary">
          Start for free
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#how-it-works" class="btn-secondary">See how it works</a>
      </div>

      <div class="hero-trust">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="6.5" stroke="var(--text-muted)" stroke-width="1.3"/>
          <path d="M5.5 8.5l2 2 3-3.5" stroke="var(--text-muted)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>No credit card required</span>
        <span class="dot-sep" aria-hidden="true">·</span>
        <span>Free tier included</span>
        <span class="dot-sep" aria-hidden="true">·</span>
        <span>Results in seconds</span>
      </div>
    </div>

    <!-- Right: Animated demo -->
    <div class="hero-demo-wrap">
      <div class="demo-card" role="img" aria-label="Demo showing AI coding survey responses in real time">
        <!-- Window chrome -->
        <div class="demo-chrome">
          <div class="traffic-lights" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <span class="demo-filename">q4_nps_verbatims.csv</span>
          <span class="demo-rowcount">4,218 rows</span>
        </div>

        <!-- Table header -->
        <div class="demo-thead">
          <span class="col-resp">Response</span>
          <span class="col-code">AI Code</span>
        </div>

        <!-- Animated response rows -->
        <div class="demo-tbody">
          <div class="demo-row" style="--d: 0.5s">
            <span class="resp-text">"The checkout feels confusing"</span>
            <span class="code-pill pill-ux">UX Friction</span>
          </div>
          <div class="demo-row" style="--d: 1.1s">
            <span class="resp-text">"Pricing too high for small teams"</span>
            <span class="code-pill pill-price">Pricing</span>
          </div>
          <div class="demo-row" style="--d: 1.7s">
            <span class="resp-text">"Support team responded quickly"</span>
            <span class="code-pill pill-pos">Positive CX</span>
          </div>
          <div class="demo-row" style="--d: 2.3s">
            <span class="resp-text">"Need a better mobile experience"</span>
            <span class="code-pill pill-feat">Feature Request</span>
          </div>
          <div class="demo-row" style="--d: 2.9s">
            <span class="resp-text">"App crashes on older Android"</span>
            <span class="code-pill pill-bug">Bug Report</span>
          </div>
        </div>

        <!-- Progress footer -->
        <div class="demo-footer">
          <div class="progress-meta">
            <span class="progress-label">Coding in progress</span>
            <span class="progress-count">2,841 / 4,218</span>
          </div>
          <div class="progress-track">
            <div class="progress-fill"></div>
          </div>
        </div>
      </div>

      <!-- Floating cost comparison badge -->
      <div class="cost-badge" aria-label="Cost comparison for this dataset">
        <div class="cost-row">
          <span class="cost-tool">Per-response tools</span>
          <span class="cost-amt cost-high">$84.36</span>
        </div>
        <div class="cost-row">
          <span class="cost-tool">Codesift</span>
          <span class="cost-amt cost-low">~$1.68</span>
        </div>
        <div class="cost-note">Estimated for this dataset</div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 144px;
    padding-bottom: 100px;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: -80px;
    left: -120px;
    width: 640px;
    height: 640px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(232, 146, 42, 0.07) 0%, transparent 68%);
    pointer-events: none;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  /* Left content */
  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: var(--amber-dim);
    border: 1px solid var(--amber-mid);
    border-radius: 100px;
    font-size: 12px;
    font-weight: 500;
    color: var(--amber);
    width: fit-content;
    margin-bottom: 28px;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--amber);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.85); }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(38px, 5vw, 62px);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: 22px;
  }

  .hero-accent {
    color: var(--amber);
  }

  .hero-sub {
    font-size: 17px;
    line-height: 1.72;
    color: var(--text-muted);
    max-width: 480px;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
    flex-wrap: wrap;
  }

  .dot-sep {
    color: var(--text-dim);
  }

  /* Right demo */
  .hero-demo-wrap {
    position: relative;
  }

  .demo-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255,255,255,0.03);
  }

  .demo-chrome {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: var(--surface-3);
    border-bottom: 1px solid var(--border);
  }

  .traffic-lights {
    display: flex;
    gap: 6px;
  }

  .traffic-lights span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--border);
  }

  .traffic-lights span:nth-child(1) { background: #E05454; opacity: 0.8; }
  .traffic-lights span:nth-child(2) { background: #E8B42A; opacity: 0.8; }
  .traffic-lights span:nth-child(3) { background: #4FCB8A; opacity: 0.8; }

  .demo-filename {
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 500;
    flex: 1;
  }

  .demo-rowcount {
    font-size: 11px;
    color: var(--text-muted);
    background: var(--border-subtle);
    padding: 2px 8px;
    border-radius: 100px;
  }

  .demo-thead {
    display: flex;
    align-items: center;
    padding: 10px 16px;
    font-size: 11px;
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border-subtle);
  }

  .col-resp { flex: 1; }
  .col-code { width: 130px; text-align: right; }

  .demo-tbody {
    padding: 4px 0;
  }

  .demo-row {
    display: flex;
    align-items: center;
    padding: 10px 16px;
    gap: 12px;
    border-bottom: 1px solid var(--border-subtle);
    opacity: 0;
    animation: rowIn 0.35s ease forwards;
    animation-delay: var(--d);
  }

  .demo-row:last-child {
    border-bottom: none;
  }

  @keyframes rowIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .resp-text {
    flex: 1;
    font-size: 13px;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .code-pill {
    flex-shrink: 0;
    font-size: 11px;
    font-family: var(--font-display);
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 100px;
    opacity: 0;
    animation: pillIn 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    animation-delay: calc(var(--d) + 0.2s);
  }

  @keyframes pillIn {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }

  .pill-ux    { background: rgba(255, 140, 80, 0.14); color: #FF8C50; border: 1px solid rgba(255, 140, 80, 0.25); }
  .pill-price { background: rgba(94, 156, 245, 0.14); color: #5E9CF5; border: 1px solid rgba(94, 156, 245, 0.25); }
  .pill-pos   { background: rgba(79, 203, 138, 0.14); color: #4FCB8A; border: 1px solid rgba(79, 203, 138, 0.25); }
  .pill-feat  { background: rgba(155, 126, 245, 0.14); color: #9B7EF5; border: 1px solid rgba(155, 126, 245, 0.25); }
  .pill-bug   { background: rgba(224, 84, 84, 0.14); color: #E05454; border: 1px solid rgba(224, 84, 84, 0.25); }

  .demo-footer {
    padding: 12px 16px;
    background: var(--surface-3);
    border-top: 1px solid var(--border);
  }

  .progress-meta {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 8px;
  }

  .progress-count {
    color: var(--amber);
    font-weight: 500;
  }

  .progress-track {
    height: 4px;
    background: var(--border);
    border-radius: 4px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--amber), #F5B84A);
    border-radius: 4px;
    width: 4%;
    animation: progressGrow 4s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    animation-delay: 0.6s;
  }

  @keyframes progressGrow {
    to { width: 67%; }
  }

  /* Floating cost badge */
  .cost-badge {
    position: absolute;
    bottom: -20px;
    left: -32px;
    background: var(--surface-3);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 14px 18px;
    min-width: 220px;
    box-shadow: var(--shadow-lg);
    animation: badgeIn 0.5s ease forwards;
    animation-delay: 3.8s;
    opacity: 0;
  }

  @keyframes badgeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .cost-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 4px 0;
  }

  .cost-tool {
    font-size: 12px;
    color: var(--text-muted);
  }

  .cost-amt {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
  }

  .cost-high {
    color: var(--red);
    text-decoration: line-through;
    text-decoration-color: rgba(224, 84, 84, 0.5);
  }

  .cost-low {
    color: var(--green);
  }

  .cost-note {
    font-size: 10px;
    color: var(--text-muted);
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid var(--border-subtle);
    text-align: center;
    letter-spacing: 0.04em;
  }

  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .hero {
      padding-top: 120px;
    }
    .cost-badge {
      left: 0;
    }
    .hero-demo-wrap {
      padding-bottom: 48px;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: clamp(32px, 9vw, 48px);
    }
    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
    }
    .hero-actions .btn-primary,
    .hero-actions .btn-secondary {
      width: 100%;
      justify-content: center;
    }
  }
</style>
