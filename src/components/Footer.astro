          <rect x="11" y="19" width="10" height="2.5" rx="1.25" fill="#E8922A" opacity="0.5"/>
          <rect x="14" y="24.5" width="4" height="2.5" rx="1.25" fill="#E8922A" opacity="0.3"/>
