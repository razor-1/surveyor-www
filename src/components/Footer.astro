<style>
  footer {
    border-top: 1px solid var(--border-subtle);
    background: var(--surface-1);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 64px;
    padding-top: 56px;
    padding-bottom: 40px;
    align-items: start;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    text-decoration: none;
  }

  .footer-tagline {
    font-size: 13px;
    color: var(--text-muted);
  }

  .footer-nav {
    display: flex;
    gap: 56px;
  }

  .footer-nav-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-nav-heading {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 4px;
  }

  .footer-nav-col a {
    font-size: 14px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-nav-col a:hover {
    color: var(--text);
  }

  .footer-bottom {
    border-top: 1px solid var(--border-subtle);
    padding: 16px 0;
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 40px;
      padding-top: 40px;
    }

    .footer-nav {
      gap: 32px;
      flex-wrap: wrap;
    }

    .footer-bottom-inner {
      flex-direction: column;
      gap: 6px;
      text-align: center;
    }
  }
</style>
